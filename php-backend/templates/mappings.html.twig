{% extends "base.html.twig" %}
{% block title %}报表配置 - AutoReport{% endblock %}
{% block content %}
<div class="flex flex-wrap items-center justify-between mb-6 gap-3">
  <div class="flex flex-wrap items-center gap-3 min-w-0">
    <h1 class="text-2xl font-bold shrink-0">报表配置</h1>
    {% if accessible_stores %}
    <form method="post" action="/demo/switch-store" class="flex flex-wrap items-center gap-2 min-w-0">
      <input type="hidden" name="next_url" value="/mappings">
      <span class="text-xs font-medium text-slate-500 shrink-0">店铺</span>
      <select name="store_id" class="store-bind-select border rounded-lg px-3 py-2 text-sm min-w-[220px] max-w-full" onchange="this.form.submit()">
        {% for store in accessible_stores %}
        <option value="{{ store.id }}" {% if current_store and store.id == current_store.id %}selected{% endif %}>
          {{ store.name }} · {{ store.platform }}
        </option>
        {% endfor %}
      </select>
    </form>
    {% endif %}
  </div>
  <div class="flex flex-wrap items-center gap-2 shrink-0">
    {% set export_ds_id = current_store ? current_store.data_source_id : (data_sources|length == 1 ? data_sources[0].id : null) %}
    {% if export_ds_id %}
    <button type="button" class="btn-export-config px-4 py-2 border border-slate-200 rounded-lg text-sm hover:bg-slate-50 text-slate-700" data-ds-id="{{ export_ds_id }}">导出 JSON</button>
    {% endif %}
    <button type="button" id="btnNewMapping" class="btn-primary text-sm font-medium px-4 py-2 rounded-lg">日报字段</button>
  </div>
</div>

<div id="toast" class="app-toast hidden" role="status" aria-live="polite"></div>

{% for ds in data_sources %}
{% set fl = file_labels_by_ds[ds.id] ?? {} %}
{% set fn = field_labels_by_ds[ds.id] ?? {} %}
<section class="mb-8">
  {% set st = (ds_settings[ds.id] ?? {}) %}
  <div class="ds-settings-card bg-white rounded-xl shadow border border-slate-200 mb-4" data-ds-id="{{ ds.id }}">
    <div class="ds-settings-body px-4 py-3">
      <div class="ds-settings-main min-w-0">
        <div class="ds-settings-head flex flex-wrap items-start justify-between gap-3 mb-2">
          <div class="ds-settings-head-title">
            <span class="section-inline-title">主表与筛选时间</span>
            <span class="text-xs text-slate-500">跨表关联与样品/刷单排除均以此为准</span>
          </div>
          <div class="ds-settings-head-actions">
            <span class="ds-timezone-label">Asia/Shanghai</span>
            <button type="button" class="btn-open-schedule px-3 py-1.5 border border-slate-200 rounded-lg text-sm hover:bg-slate-50 text-slate-700 whitespace-nowrap" data-ds-id="{{ ds.id }}">
              每日自动生成 · <span class="ds-schedule-label">{% if st and st.daily_generate_at %}{{ st.daily_generate_at }}{% else %}未设置{% endif %}</span>
            </button>
            <button type="button" class="btn-save-ds-settings px-4 py-1.5 btn-primary text-sm whitespace-nowrap">保存</button>
          </div>
        </div>
        <div class="ds-baseline-grid">
          <div class="ds-field">
            <label class="ds-field-label">来源文件</label>
            <div class="ds-order-file-host"></div>
          </div>
          <div class="ds-field">
            <label class="ds-field-label">Sheet</label>
            <div class="ds-order-sheet-host"></div>
          </div>
          <div class="ds-field">
            <label class="ds-field-label">日期列</label>
            <div class="ds-order-date-col-host"></div>
          </div>
        </div>
      </div>
    </div>
  </div>

  {% set excel_rows = (excel_config[ds.id] ?? []) %}
  {% if excel_rows %}
  <div class="section-table-card bg-white rounded-xl shadow border border-slate-200 overflow-x-auto mb-4">
    <div class="section-table-header">
      <div class="section-table-header-main">
        <span class="section-table-title">日报字段</span>
        <span class="section-table-count">{{ excel_rows|length }}</span>
      </div>
      <span class="section-table-hint" title="在日报输出页可拖动调整列顺序">顺序与日报页同步</span>
    </div>
    <table class="w-full text-sm min-w-[860px] app-table">
      <thead class="bg-slate-50 text-left text-slate-500 text-xs">
        <tr>
          <th class="px-4 py-2 w-14">Excel</th>
          <th class="px-4 py-2 w-16">类型</th>
          <th class="px-4 py-2">指标名称</th>
          <th class="px-4 py-2">规则摘要</th>
          <th class="px-4 py-2 w-36"></th>
        </tr>
      </thead>
      <tbody>
        {% for row in excel_rows %}
        {% set m = row.mapping %}
        <tr id="report-field-{{ m.id }}" class="border-t border-slate-100 hover:bg-slate-50 transition-colors">
          <td class="px-4 py-3 font-mono text-xs text-slate-500">{{ row.col }}</td>
          <td class="px-4 py-3">
            {% include "partials/field_type_tag.html.twig" %}
          </td>
          <td class="px-4 py-3">
            <div class="font-medium">{{ row.label }}</div>
            <div class="field-code-hint" title="{field:{{ row.line_code }}}">{field:{{ row.line_code }}}</div>
          </td>
          <td class="px-4 py-3 text-xs max-w-[320px]">
            {% set ds_id = ds.id %}{% set ds_settings_entry = st %}
            {% include "partials/report_rule_summary.html.twig" %}
          </td>
          <td class="px-4 py-3">
            {% set ds_id = ds.id %}
            {% include "partials/report_rule_actions.html.twig" %}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% endif %}

  {% set aux = (auxiliary[ds.id] ?? []) %}
  {% if aux %}
  <div id="aux-fields-{{ ds.id }}" class="section-table-card bg-white rounded-xl shadow border border-slate-200 overflow-hidden mb-4" data-ds-id="{{ ds.id }}">
    <button type="button" class="section-table-header section-table-header--toggle aux-fields-toggle w-full text-left" aria-expanded="true" aria-controls="aux-body-{{ ds.id }}">
      <div class="section-table-header-main">
        <span class="section-table-title">基础取数字段</span>
        <span class="section-table-count">{{ aux|length }}</span>
        <span class="field-type-tag field-type-tag--aux">基础取值数据</span>
      </div>
      <span class="section-table-chevron" aria-hidden="true">›</span>
    </button>
    <div class="aux-first-use-banner" data-ds-id="{{ ds.id }}" role="note">
      <div class="aux-first-use-banner-body">
        <strong>初次配置？</strong>
        <span>组合指标（如实际支付金额）会引用此处的基础字段。请先配置基础取数，再编辑上方日报字段。</span>
      </div>
      <button type="button" class="aux-first-use-dismiss" aria-label="知道了">知道了</button>
    </div>
    <div id="aux-body-{{ ds.id }}" class="aux-fields-body overflow-x-auto">
      <table class="w-full text-sm min-w-[720px] app-table">
        <thead class="bg-slate-50 text-left text-slate-500 text-xs">
          <tr>
            <th class="px-4 py-2">字段名称</th>
            <th class="px-4 py-2">规则摘要</th>
            <th class="px-4 py-2 w-36"></th>
          </tr>
        </thead>
        <tbody>
          {% for item in aux %}
          {% set m = item.mapping %}
          <tr id="aux-field-{{ m.id }}" class="border-t border-slate-100 hover:bg-slate-50 transition-colors">
            <td class="px-4 py-3">
              <div class="font-medium">{{ item.label }}</div>
              <div class="field-code-hint" title="{field:{{ item.line_code }}}">{field:{{ item.line_code }}}</div>
            </td>
            <td class="px-4 py-3 text-xs max-w-[320px]">
              {% set row = item %}{% set ds_id = ds.id %}{% set ds_settings_entry = st %}
              {% if m.parts %}
                {% for p in m.parts|sort((a, b) => a.sort_order <=> b.sort_order) %}
                <div class="rule-summary-line">
                  <span class="rule-summary-text">{% if not loop.first and p.combine_op == 'subtract' %}− {% elseif not loop.first %}＋ {% endif %}{{ p | part_rule_brief(fl, fn) }}</span>
                </div>
                {% endfor %}
              {% elseif item.field_type == 'placeholder' %}
              <span class="rule-summary-text">占位，导出后手工填写或上传文件</span>
              {% else %}
              <span class="rule-summary-empty">未配置取数</span>
              {% endif %}
            </td>
            <td class="px-4 py-3">
              {% include "partials/report_rule_actions.html.twig" %}
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
  {% elseif not excel_rows %}
  <div class="bg-white rounded-xl border border-dashed border-slate-200 p-8 text-center text-slate-400 text-sm">暂无配置，请添加日报字段</div>
  {% endif %}
</section>

{% endfor %}

<!-- 取数弹窗 -->
{% set modal_data_sources = data_sources %}
{% set modal_fields = fields %}
{% include "partials/mapping_modal.html.twig" %}

{% include "partials/review_settings_modal.html.twig" %}
{% include "partials/schedule_settings_modal.html.twig" %}
{% include "partials/review_template_download_modal.html.twig" %}

<script>window.CURRENT_STORE_DS_ID = {{ current_store ? current_store.data_source_id : (data_sources ? data_sources[0].id : 'null') }};</script>

<script>window.DATA_SOURCE_META = {{ meta_json |raw }};</script>
<script>window.DS_SETTINGS = {{ ds_settings_json |raw }};</script>
<script>window.REUSE_FIELDS_BY_DS = {{ reuse_fields_json |raw }};</script>
<script src="/static/app_toast.js?v=20260708b"></script>
<script src="/static/app_modal.js?v=20260708v"></script>
<script src="/static/form_controls.js?v=20260709b"></script>
<script src="/static/mappings_settings.js?v=20260709a"></script>
<script src="/static/mapping_modal.js?v=20260708v"></script>
<script>
document.addEventListener('DOMContentLoaded', () => {
  const hash = location.hash;
  if (!hash.startsWith('#report-field-') && !hash.startsWith('#aux-field-')) return;
  const el = document.querySelector(hash);
  if (!el) return;
  if (hash.startsWith('#aux-field-')) {
    const panel = el.closest('[id^="aux-fields-"]');
    const body = panel?.querySelector('.aux-fields-body');
    const toggle = panel?.querySelector('.aux-fields-toggle');
    if (body) body.classList.remove('is-collapsed');
    if (toggle) toggle.setAttribute('aria-expanded', 'true');
  }
  setTimeout(() => {
    el.scrollIntoView({ behavior: 'smooth', block: 'center' });
    el.classList.add('ring-2', 'ring-sky-400', 'ring-offset-2');
    setTimeout(() => el.classList.remove('ring-2', 'ring-sky-400', 'ring-offset-2'), 2400);
  }, 120);
});
</script>
{% endblock %}
