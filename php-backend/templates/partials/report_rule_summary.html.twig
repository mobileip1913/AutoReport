{# 报表字段规则摘要（报表配置 / 日报输出共用） #}

{% set fl = file_labels_by_ds[ds_id] ?? {} %}
{% set fn = field_labels_by_ds[ds_id] ?? {} %}
{% if row.field_type == 'placeholder' %}

<span class="rule-summary-text">占位，导出后手工填写或上传文件</span>

{% elseif row.field_type == 'per_order' %}

<span class="rule-summary-text">每单 ${{ (m.per_order_amount ?? 0)|number_format(4, '.', '')|trim('0', 'right')|trim('.', 'right') }} × {% if m.per_order_basis == 'review_orders' %}刷单单数{% else %}当日有效订单数{% endif %}</span>

{% elseif row.field_type == 'ratio' %}

<span class="rule-summary-text">{{ fn[m.ratio_base_code] ?? (m.ratio_base_code ?: '基准字段') }} × {{ (m.ratio_percent ?? 0)|number_format(4, '.', '')|trim('0', 'right')|trim('.', 'right') }}%</span>

{% elseif row.field_type == 'formula' %}

<span class="rule-summary-text">{{ (m.expression ?: '公式行')|slice(0, 48) }}{% if m.expression and m.expression|length > 48 %}…{% endif %}</span>

{% elseif row.field_type == 'review' or row.line_code in review_import_codes %}

{% if row.line_code in review_logistics_codes %}

<span class="rule-summary-text review-logistics-rule-summary" data-ds-id="{{ ds_id }}">{{ ds_settings_entry.review_logistics_rule_summary is defined and ds_settings_entry.review_logistics_rule_summary ? ds_settings_entry.review_logistics_rule_summary : '按单固定 $1/单' }}</span>

{% else %}

<span class="rule-summary-text">刷单 Excel 导入汇总</span>

{% endif %}

{% elseif row.field_type == 'sample' %}

<span class="rule-summary-text">样品单 Excel 导入汇总</span>

{% elseif m.parts %}

  {% for p in m.parts|sort((a, b) => a.sort_order <=> b.sort_order) %}

  <div class="rule-summary-line">

    <span class="rule-summary-text">{% if not loop.first and p.combine_op == 'subtract' %}− {% elseif not loop.first %}＋ {% endif %}{{ p|part_rule_brief(fl, fn) }}</span>

  </div>

  {% endfor %}

{% else %}

<span class="rule-summary-empty">未配置取数</span>

{% endif %}
