{# 报表字段操作按钮（报表配置 / 日报输出共用） #}
{% set _del_label = (row is defined ? row.label : '') ?: (item is defined ? item.label : '') ?: m.excel_label ?: m.label ?: '' %}
<div class="report-rule-actions">
  <button type="button" class="btn-edit text-link hover:underline text-xs" data-id="{{ m.id }}">配置</button>
  <button type="button" class="btn-delete-mapping btn-modal-danger btn-modal-danger--compact" data-id="{{ m.id }}" data-label="{{ _del_label }}">删除</button>
</div>
