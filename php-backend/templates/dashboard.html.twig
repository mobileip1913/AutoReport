{% extends "base.html.twig" %}
{% block title %}概览 - AutoReport{% endblock %}
{% block content %}
<div class="page-header mb-8">
  <h1 class="text-3xl font-bold text-slate-900" style="text-wrap: balance">跨境电商自动报表 Demo</h1>
  <p class="mt-2 text-slate-600" style="text-wrap: pretty">财务自定义模板与字段映射 → 自动解析 Excel → 生成统一口径日经营报表</p>
</div>

<div class="grid md:grid-cols-3 gap-6 mb-8 page-stagger">
  <div class="app-card p-6">
    <div class="text-sm text-slate-500">已接入店铺</div>
    <div class="app-stat-value mt-1">{{ data_sources|length }}</div>
    <div class="text-xs text-slate-400 mt-2">启动时自动注册，无需手动配置</div>
  </div>
  <div class="app-card p-6">
    <div class="text-sm text-slate-500">报表模板</div>
    <div class="app-stat-value mt-1">{{ templates_list|length }}</div>
    <div class="text-xs text-slate-400 mt-2">支持草稿 → 测试 → 发布</div>
  </div>
  <div class="app-card p-6">
    <div class="text-sm text-slate-500">最近生成</div>
    <div class="app-stat-value mt-1">{{ recent_runs|length }}</div>
    <div class="text-xs text-slate-400 mt-2">含测试与正式报表</div>
  </div>
</div>

<div class="grid lg:grid-cols-2 gap-6 page-stagger">
  <section class="app-card app-card--static p-6">
    <h2 class="text-lg font-semibold mb-4">快速开始</h2>
    <ol class="space-y-3 text-sm text-slate-700 list-decimal list-inside">
      <li>在 <a href="/mappings" class="text-link text-link--underline">报表配置</a> 查看或调整各指标的取数规则与公式</li>
      <li>在 <a href="/daily" class="text-link text-link--underline">日报输出</a> 选择日期生成报表并导出 Excel</li>
    </ol>
  </section>

  <section class="app-card app-card--static p-6">
    <h2 class="text-lg font-semibold mb-4">最近生成</h2>
    {% if recent_runs %}
    <ul class="space-y-2">
      {% for run in recent_runs|slice(0, 6) %}
      <li class="text-sm p-3 bg-slate-50 border border-slate-100 rounded-lg">
        <span class="text-slate-700">{{ run.store_name }}</span>
        <span class="text-slate-400 mx-1">·</span>
        <span class="text-slate-500">{{ run.report_date }}</span>
        <a href="/daily?run_id={{ run.id }}" class="text-link text-xs ml-2 hover:underline">查看 →</a>
      </li>
      {% endfor %}
    </ul>
    {% else %}
    <p class="text-sm text-slate-500">暂无报表记录</p>
    {% endif %}
  </section>
</div>

<section class="mt-6 app-card app-card--static p-6 page-stagger">
  <h2 class="text-lg font-semibold mb-4">报表模板</h2>
  <div class="overflow-x-auto">
    <table class="app-table w-full text-sm">
      <thead class="text-left text-slate-500 border-b">
        <tr>
          <th class="py-2">名称</th>
          <th>状态</th>
          <th>版本</th>
          <th>负责人</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {% for t in templates_list %}
        <tr class="border-b border-slate-50">
          <td class="py-3 font-medium">{{ t.name }}</td>
          <td>
            {% if t.status == 'published' %}
            <span class="px-2 py-0.5 rounded-full bg-green-100 text-green-700 text-xs">已发布 v{{ t.version }}</span>
            {% else %}
            <span class="px-2 py-0.5 rounded-full bg-slate-100 text-slate-600 text-xs">草稿</span>
            {% endif %}
          </td>
          <td>{{ t.version }}</td>
          <td>{{ t.owner }}</td>
          <td><a href="/templates/{{ t.id }}" class="text-link row-action">进入 →</a></td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>
{% endblock %}
