<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}AutoReport{% endblock %}</title>
  <link rel="stylesheet" href="/static/tailwind.css">
  <link rel="stylesheet" href="/static/style.css?v=20260709n">
</head>
<body class="min-h-screen">
  <nav class="app-nav">
    <div class="max-w-7xl mx-auto px-4 py-3 flex items-center gap-3">
      <a href="/" class="app-nav-brand shrink-0">AutoReport</a>
      <div class="app-nav-links ml-auto">
        <a href="/" class="app-nav-link {% if path == '/' %}is-active{% endif %}">概览</a>
        <a href="/mappings" class="app-nav-link {% if path starts with '/mappings' %}is-active{% endif %}">报表配置</a>
        <a href="/daily" class="app-nav-link {% if path starts with '/daily' %}is-active{% endif %}">日报输出</a>
      </div>
      {% if current_account %}
      <div class="nav-account shrink-0" data-nav-account>
        <button type="button" class="nav-account-trigger" data-nav-account-trigger aria-expanded="false" aria-haspopup="listbox">
          <span class="nav-account-avatar">{{ current_account.display_name|slice(0, 1) }}</span>
          <span class="nav-account-label">{{ current_account.display_name }}</span>
          <svg class="nav-account-chevron" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.94a.75.75 0 111.08 1.04l-4.24 4.5a.75.75 0 01-1.08 0l-4.24-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd"/>
          </svg>
        </button>
        <div class="nav-account-panel" data-nav-account-panel role="listbox">
          <div class="nav-account-panel-header">切换 Demo 账号</div>
          {% for item in account_menu %}
          <form method="post" action="/demo/switch-account">
            <input type="hidden" name="next_url" value="{{ path }}">
            <input type="hidden" name="account_id" value="{{ item.id }}">
            <button type="submit"
                    class="nav-account-option {% if item.id == current_account.id %}is-active{% endif %}"
                    role="option" aria-selected="{{ item.id == current_account.id ? 'true' : 'false' }}">
              <span class="nav-account-option-avatar">{{ item.initial }}</span>
              <span class="nav-account-option-body">
                <span class="nav-account-option-name">{{ item.display_name }}</span>
                <span class="nav-account-option-hint">{{ item.store_hint }}</span>
              </span>
              <svg class="nav-account-check" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/>
              </svg>
            </button>
          </form>
          {% endfor %}
        </div>
      </div>
      {% endif %}
    </div>
  </nav>
  <main class="max-w-7xl mx-auto px-4 py-8">
    {% block content %}{% endblock %}
  </main>
  {% block scripts %}{% endblock %}
  <script>
  (function () {
    var root = document.querySelector('[data-nav-account]');
    if (!root) return;
    var trigger = root.querySelector('[data-nav-account-trigger]');
    var panel = root.querySelector('[data-nav-account-panel]');
    if (!trigger || !panel) return;

    function close() {
      panel.classList.remove('is-open');
      trigger.setAttribute('aria-expanded', 'false');
    }

    trigger.addEventListener('click', function (e) {
      e.stopPropagation();
      var open = panel.classList.toggle('is-open');
      trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
    });

    document.addEventListener('click', close);
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') close();
    });
  })();
  </script>
</body>
</html>
