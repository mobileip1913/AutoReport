{
    "name": "autoreport/php-backend",
    "description": "AutoReport 跨境电商自动报表 Demo - PHP 后端（与 Python FastAPI 版功能对等）",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "ext-pdo": "*",
        "slim/slim": "^4.14",
        "slim/psr7": "^1.7",
        "twig/twig": "^3.14",
        "phpoffice/phpspreadsheet": "^2.3",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
